//trig
extern fn toy_math_sin(a: c_int64_t): int;
extern fn toy_math_sinf(a: c_double): float;
export fn sin(a: int): int {
    return toy_math_sin(a);
}
export fn sin(a: float): float {
    return toy_math_sinf(a);
}

